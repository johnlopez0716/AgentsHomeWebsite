# Copy this file to .env and fill in real values
# Never commit .env to git

# Server
PORT=8080
NODE_ENV=production

# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Follow Up Boss — API key from https://app.followupboss.com/2/api
FUB_API_KEY=your_fub_api_key_here

# SISU — full Authorization header value (e.g. "Bearer xxxx" or "Token xxxx")
SISU_AUTH=Bearer your_sisu_token_here

# Optional
LOG_LEVEL=info
